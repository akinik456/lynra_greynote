        <mxCell id="x52I7BFvqtoLllKQRu75-35" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="initState" vertex="1">
